# Server
PORT=4174
HOST=0.0.0.0
KH_DATA_DIR=./data
KH_JWT_SECRET=change-me-to-a-long-random-string

# 数据库（必填）：PostgreSQL 连接串。
# 默认值与仓库自带的 docker-compose.yml 一致 —— 用 `npm run db:up` 起库即可零配置连上。
DATABASE_URL=postgres://postgres:khpw@127.0.0.1:5432/knowledge_hub

# PostgreSQL（测试用，单元测试始终使用外部 PG 以保证 schema 隔离）
KH_TEST_DATABASE_URL=postgres://postgres:khpw@127.0.0.1:5432/knowledge_hub_test

# ── Docker 部署（应用进容器、数据库用外部 PG、不使用 5432）──
# 容器内 127.0.0.1 指向容器自身，连宿主机 PG 要用 host.docker.internal；端口用你的非 5432 端口（示例 5544）。
# 数据库在独立服务器时，把 host.docker.internal 换成那台 DB 的 IP/域名。部署时取消注释并覆盖上面的 DATABASE_URL：
# DATABASE_URL=postgres://postgres:khpw@host.docker.internal:5544/knowledge_hub
# docker-compose.prod.yml 自带 PostgreSQL 时必须显式配置，建议生产环境改成长随机值。
# POSTGRES_PASSWORD=change-me-to-a-long-random-password
# APP_HOST_PORT=4174

# Web 上传原始资料限制。
# 默认单文件 2GB；如果部署在 Nginx/云网关后，还需要同步调大代理的上传上限。
KH_UPLOAD_MAX_FILE_BYTES=2147483648
KH_UPLOAD_MAX_FILES=20000
KH_UPLOAD_MAX_FIELDS=200
KH_UPLOAD_MAX_PARTS=20200

# Knowledge Builder
# extract 阶段调用 LLM 时的输出上限（tokens）。文档越长越复杂越要调高。
# Anthropic Sonnet/Opus 支持 64K+；OpenAI gpt-4.1 系列 16K+。
KH_KB_EXTRACT_MAX_TOKENS=4096

# "测试模型连接"按钮的探针请求 max_tokens，保持小值即可。
KH_MODEL_PROBE_MAX_TOKENS=1

# OpenAI 兜底（可选）：仅在前端未显式选择 LLM provider 时使用。
# 前端「知识构建 → 高级选项」配置的 modelConfig 会覆盖这里。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
